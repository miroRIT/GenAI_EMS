{
  "components": {
    "schemas": {
      "BestRouteResponse": {
        "properties": {
          "alternatives": {
            "items": {
              "$ref": "#/components/schemas/BestRouteResponse"
            },
            "title": "Alternatives",
            "type": "array"
          },
          "estimated_distance_meters": {
            "title": "Estimated Distance Meters",
            "type": "integer"
          },
          "estimated_duration_seconds": {
            "title": "Estimated Duration Seconds",
            "type": "integer"
          },
          "priority_savings_seconds": {
            "title": "Priority Savings Seconds",
            "type": "integer"
          },
          "rationale": {
            "title": "Rationale",
            "type": "string"
          },
          "route_polyline": {
            "items": {
              "$ref": "#/components/schemas/Coordinate"
            },
            "title": "Route Polyline",
            "type": "array"
          },
          "segments": {
            "items": {
              "$ref": "#/components/schemas/RouteSegment"
            },
            "title": "Segments",
            "type": "array"
          },
          "signal_delay_seconds": {
            "title": "Signal Delay Seconds",
            "type": "integer"
          },
          "traffic_adjusted_duration_seconds": {
            "title": "Traffic Adjusted Duration Seconds",
            "type": "integer"
          }
        },
        "required": [
          "estimated_distance_meters",
          "estimated_duration_seconds",
          "traffic_adjusted_duration_seconds",
          "signal_delay_seconds",
          "priority_savings_seconds",
          "route_polyline",
          "segments",
          "rationale"
        ],
        "title": "BestRouteResponse",
        "type": "object"
      },
      "Body_issue_token_api_v1_auth_token_post": {
        "properties": {
          "client_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Id"
          },
          "client_secret": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Secret"
          },
          "grant_type": {
            "anyOf": [
              {
                "pattern": "password",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Grant Type"
          },
          "password": {
            "title": "Password",
            "type": "string"
          },
          "scope": {
            "default": "",
            "title": "Scope",
            "type": "string"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "Body_issue_token_api_v1_auth_token_post",
        "type": "object"
      },
      "Coordinate": {
        "properties": {
          "latitude": {
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Latitude",
            "type": "number"
          },
          "longitude": {
            "maximum": 180.0,
            "minimum": -180.0,
            "title": "Longitude",
            "type": "number"
          }
        },
        "required": [
          "latitude",
          "longitude"
        ],
        "title": "Coordinate",
        "type": "object"
      },
      "DispatchDecision": {
        "properties": {
          "alternatives": {
            "items": {
              "$ref": "#/components/schemas/RoutePlan"
            },
            "title": "Alternatives",
            "type": "array"
          },
          "assigned_at": {
            "format": "date-time",
            "title": "Assigned At",
            "type": "string"
          },
          "incident_id": {
            "format": "uuid",
            "title": "Incident Id",
            "type": "string"
          },
          "selected_route": {
            "$ref": "#/components/schemas/RoutePlan"
          },
          "severity": {
            "$ref": "#/components/schemas/IncidentSeverity"
          }
        },
        "required": [
          "severity",
          "selected_route",
          "alternatives"
        ],
        "title": "DispatchDecision",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "IncidentCreate": {
        "properties": {
          "destination": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Coordinate"
              },
              {
                "type": "null"
              }
            ]
          },
          "notes": {
            "anyOf": [
              {
                "maxLength": 1000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          },
          "patient_location": {
            "$ref": "#/components/schemas/Coordinate"
          },
          "severity": {
            "$ref": "#/components/schemas/IncidentSeverity"
          }
        },
        "required": [
          "patient_location",
          "severity"
        ],
        "title": "IncidentCreate",
        "type": "object"
      },
      "IncidentSeverity": {
        "enum": [
          "critical",
          "high",
          "medium",
          "low"
        ],
        "title": "IncidentSeverity",
        "type": "string"
      },
      "RouteCalculationRequest": {
        "properties": {
          "destination": {
            "$ref": "#/components/schemas/Coordinate"
          },
          "include_alternatives": {
            "default": true,
            "title": "Include Alternatives",
            "type": "boolean"
          },
          "origin": {
            "$ref": "#/components/schemas/Coordinate"
          },
          "priority": {
            "allOf": [
              {
                "$ref": "#/components/schemas/RoutePriority"
              }
            ],
            "default": "emergency"
          },
          "traffic_level": {
            "default": 1.0,
            "description": "Traffic multiplier supplied by an upstream traffic service.",
            "maximum": 2.5,
            "minimum": 0.5,
            "title": "Traffic Level",
            "type": "number"
          },
          "use_signal_priority": {
            "default": true,
            "title": "Use Signal Priority",
            "type": "boolean"
          }
        },
        "required": [
          "origin",
          "destination"
        ],
        "title": "RouteCalculationRequest",
        "type": "object"
      },
      "RoutePlan": {
        "properties": {
          "ambulance_id": {
            "format": "uuid",
            "title": "Ambulance Id",
            "type": "string"
          },
          "distance_to_patient_meters": {
            "title": "Distance To Patient Meters",
            "type": "integer"
          },
          "estimated_arrival_seconds": {
            "title": "Estimated Arrival Seconds",
            "type": "integer"
          },
          "estimated_transport_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Estimated Transport Seconds"
          },
          "incident_id": {
            "format": "uuid",
            "title": "Incident Id",
            "type": "string"
          },
          "rationale": {
            "title": "Rationale",
            "type": "string"
          },
          "route_polyline": {
            "items": {
              "$ref": "#/components/schemas/Coordinate"
            },
            "title": "Route Polyline",
            "type": "array"
          },
          "total_score": {
            "title": "Total Score",
            "type": "number"
          }
        },
        "required": [
          "ambulance_id",
          "incident_id",
          "estimated_arrival_seconds",
          "distance_to_patient_meters",
          "total_score",
          "route_polyline",
          "rationale"
        ],
        "title": "RoutePlan",
        "type": "object"
      },
      "RoutePriority": {
        "enum": [
          "emergency",
          "urgent",
          "routine"
        ],
        "title": "RoutePriority",
        "type": "string"
      },
      "RouteSegment": {
        "properties": {
          "distance_meters": {
            "title": "Distance Meters",
            "type": "integer"
          },
          "end": {
            "$ref": "#/components/schemas/Coordinate"
          },
          "estimated_seconds": {
            "title": "Estimated Seconds",
            "type": "integer"
          },
          "instruction": {
            "title": "Instruction",
            "type": "string"
          },
          "start": {
            "$ref": "#/components/schemas/Coordinate"
          }
        },
        "required": [
          "start",
          "end",
          "distance_meters",
          "estimated_seconds",
          "instruction"
        ],
        "title": "RouteSegment",
        "type": "object"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "token_type": {
            "default": "bearer",
            "title": "Token Type",
            "type": "string"
          }
        },
        "required": [
          "access_token"
        ],
        "title": "TokenResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "flows": {
          "password": {
            "scopes": {
              "dispatch:read": "Read dispatch decisions and route plans.",
              "dispatch:write": "Create incidents and assign ambulances.",
              "health:read": "Read operational health information."
            },
            "tokenUrl": "/api/v1/auth/token"
          }
        },
        "type": "oauth2"
      }
    }
  },
  "info": {
    "description": "EmergencyPulse optimizes ambulance assignment using patient criticality, ambulance capability, traffic conditions, signal timing proxies, and spatial distance.",
    "summary": "Geospatial emergency ambulance routing and dispatch API.",
    "title": "EmergencyPulse",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/v1/auth/token": {
      "post": {
        "description": "Authenticates a dispatcher with form credentials and returns a bearer token for testing secured dispatch APIs in Swagger UI.",
        "operationId": "issue_token_api_v1_auth_token_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_issue_token_api_v1_auth_token_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                  "token_type": "bearer"
                },
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Bearer token issued."
          },
          "401": {
            "description": "Invalid username or password."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Issue an operator access token",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/dispatch/incidents": {
      "post": {
        "description": "Scores available ambulances by estimated arrival time, traffic proxy, signal timing penalty, incident severity, and equipment capability, then persists the assignment.",
        "operationId": "dispatch_incident_api_v1_dispatch_incidents_post",
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "criticalCardiacIncident": {
                  "description": "Dispatch an ALS-capable ambulance near Midtown Manhattan.",
                  "summary": "Critical cardiac incident",
                  "value": {
                    "destination": {
                      "latitude": 40.7648,
                      "longitude": -73.9808
                    },
                    "notes": "Chest pain with shortness of breath",
                    "patient_location": {
                      "latitude": 40.7584,
                      "longitude": -73.9857
                    },
                    "severity": "critical"
                  }
                },
                "lowSeverityTransport": {
                  "description": "Dispatch a basic life support unit for a stable patient.",
                  "summary": "Low severity transport",
                  "value": {
                    "notes": "Stable patient transfer request",
                    "patient_location": {
                      "latitude": 40.7306,
                      "longitude": -73.9352
                    },
                    "severity": "low"
                  }
                }
              },
              "schema": {
                "$ref": "#/components/schemas/IncidentCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DispatchDecision"
                }
              }
            },
            "description": "Incident dispatched and ranked alternatives returned."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Bearer token does not include dispatch:write scope."
          },
          "409": {
            "description": "No available ambulances are online."
          },
          "422": {
            "description": "Request validation failed."
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": [
              "dispatch:write"
            ]
          }
        ],
        "summary": "Dispatch the best ambulance for an incident",
        "tags": [
          "dispatch"
        ]
      }
    },
    "/api/v1/routes/best": {
      "post": {
        "description": "Calculates an optimized ambulance or healthcare-service route from origin to destination using distance, traffic level, intersection delay, and optional emergency signal-priority savings. This endpoint is intentionally public so healthcare integrations can validate route estimates without creating a dispatch.",
        "operationId": "calculate_best_route_api_v1_routes_best_post",
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "emergencyAmbulanceRoute": {
                  "description": "Calculate an emergency route to a trauma center.",
                  "summary": "Emergency ambulance route",
                  "value": {
                    "destination": {
                      "latitude": 40.7648,
                      "longitude": -73.9808
                    },
                    "include_alternatives": true,
                    "origin": {
                      "latitude": 40.7584,
                      "longitude": -73.9857
                    },
                    "priority": "emergency",
                    "traffic_level": 1.35,
                    "use_signal_priority": true
                  }
                },
                "routineHealthcareTransfer": {
                  "description": "Estimate route timing without emergency preemption.",
                  "summary": "Routine healthcare transfer",
                  "value": {
                    "destination": {
                      "latitude": 40.706,
                      "longitude": -74.0086
                    },
                    "include_alternatives": false,
                    "origin": {
                      "latitude": 40.7306,
                      "longitude": -73.9352
                    },
                    "priority": "routine",
                    "traffic_level": 1.1,
                    "use_signal_priority": false
                  }
                }
              },
              "schema": {
                "$ref": "#/components/schemas/RouteCalculationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BestRouteResponse"
                }
              }
            },
            "description": "Best route calculation returned."
          },
          "422": {
            "description": "Request validation failed."
          }
        },
        "summary": "Calculate the best open healthcare route",
        "tags": [
          "routes"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "Returns ok when the API process is running.",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "API process is live."
          }
        },
        "summary": "Liveness check",
        "tags": [
          "health"
        ]
      }
    },
    "/readyz": {
      "get": {
        "description": "Verifies the API can reach the database before receiving traffic.",
        "operationId": "readyz_readyz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "API and database are ready."
          },
          "503": {
            "description": "Database is unavailable."
          }
        },
        "summary": "Readiness check",
        "tags": [
          "health"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Local development",
      "url": "http://localhost:8080"
    },
    {
      "description": "Staging",
      "url": "https://api.staging.emergencypulse.example"
    },
    {
      "description": "Production",
      "url": "https://api.emergencypulse.example"
    }
  ],
  "tags": [
    {
      "description": "Readiness and liveness endpoints for load balancers and deployment checks.",
      "name": "health"
    },
    {
      "description": "JWT token issuance for dispatch operators and system integrations.",
      "name": "auth"
    },
    {
      "description": "Incident intake and ambulance route assignment APIs.",
      "name": "dispatch"
    },
    {
      "description": "Open route calculation APIs for healthcare services.",
      "name": "routes"
    }
  ]
}
